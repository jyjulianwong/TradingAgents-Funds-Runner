# ------------------------------------------------------------------------------
# TradingAgents LLM provider
# ------------------------------------------------------------------------------
# Set the key for the provider you use; leave the rest blank.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Others: XAI_API_KEY, DEEPSEEK_API_KEY, GROQ_API_KEY, OPENROUTER_API_KEY,
#         MISTRAL_API_KEY, MOONSHOT_API_KEY, NVIDIA_API_KEY, DASHSCOPE_API_KEY

# ------------------------------------------------------------------------------
# TradingAgents data vendor API keys
# ------------------------------------------------------------------------------
# FRED: Federal Reserve macro data (rates, inflation, labour, growth).
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Alpha Vantage: optional alternative to yfinance for price/fundamental data.
# Free key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Reddit RSS: optional authenticated feed token to avoid 429 rate-limiting.
# Obtain from https://www.reddit.com/prefs/feeds/
#REDDIT_RSS_FEED_TOKEN=
#REDDIT_USERNAME=

# ------------------------------------------------------------------------------
# TradingAgents configuration
# ------------------------------------------------------------------------------
# These map 1-to-1 to TRADINGAGENTS_* env vars in TradingAgents-Funds.
# Any unset variable falls back to DEFAULT_CONFIG in the library.
TRADINGAGENTS_LLM_PROVIDER=openai
TRADINGAGENTS_DEEP_THINK_LLM=gpt-4o
TRADINGAGENTS_QUICK_THINK_LLM=gpt-4o-mini

# Must be false when running inside Docker — no display is available.
# (Also hardcoded off in runner/main.py as a safeguard.)
TRADINGAGENTS_ENABLE_VISUALIZER=false

# Analysts to run (comma-separated). Uncomment to fix the selection and skip
# the interactive prompt; the runner's config.py ANALYSTS list takes precedence
# over this when using the programmatic API, but this acts as a fallback.
#TRADINGAGENTS_ANALYSTS=market,social,news,fundamentals

# Optional: override analysis date (YYYY-MM-DD). The runner reads ANALYSIS_DATE
# from config.py first; this env var is a secondary override for the library itself.
#TRADINGAGENTS_ANALYSIS_DATE=2026-07-18

# Optional: LLM sampling temperature (lower = less run-to-run variation).
#TRADINGAGENTS_TEMPERATURE=0.0

# Optional: SDK retry budget — raise to survive bursty 429 throttling.
#TRADINGAGENTS_LLM_MAX_RETRIES=6

# ------------------------------------------------------------------------------
# AWS credentials (used by the runner to upload to S3)
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-2

# ------------------------------------------------------------------------------
# Runner: S3 output bucket
# ------------------------------------------------------------------------------
# Set this to the value of `reports_bucket_name` from `terraform output`.
AWS_S3_REPORTS_BUCKET_NAME=
